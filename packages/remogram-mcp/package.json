{
  "name": "@remogram/mcp",
  "version": "0.1.0-beta.12",
  "description": "Remogram MCP server delegating to CLI",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/attebury/remogram.git",
    "directory": "packages/remogram-mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
