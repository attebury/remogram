verification verification_cr_inventory_list_v2_cr_followup {
  name "CR inventory list v2 cr follow-up proof"
  description "npm test proof for trusted entry_count fallback, tail-page recent_created, and number-sort full collect."
  validates [cap_forge_remote_ops]
  method runtime
  scenarios [cr_inventory_list_v2_cr_followup]
  proof_commands {
    command npm_test argv ["npm" "test"]
  }
  status draft
}
