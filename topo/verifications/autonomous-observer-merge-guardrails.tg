verification verification_autonomous_observer_merge_guardrails {
  name "Autonomous Observer merge guardrails proof"
  description "Unit tests for path allowlist helper used by autonomous Observer auto-merge scope checks."
  validates [cap_forge_remote_ops]
  method runtime
  scenarios [autonomous_observer_merge_guardrails]
  proof_commands {
    command npm_test argv ["npm" "test" "tests/core/path-allowlist.test.mjs"]
  }
  status active
}
