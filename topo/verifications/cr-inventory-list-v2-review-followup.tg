verification verification_cr_inventory_list_v2_review_followup {
  name "CR inventory list v2 review follow-up proof"
  description "npm test proof for Gitea recent_created, fast-path sanity, and sort contract tests."
  validates [cap_forge_remote_ops]
  method runtime
  scenarios [cr_inventory_list_v2_review_followup]
  proof_commands {
    command npm_test argv ["npm" "test"]
  }
  status draft
}
