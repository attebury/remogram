verification verification_github_api_provider {
  name "GitHub api provider test suite"
  description "Mocked-fetch provider tests proving envelope parity, check normalization, mergeability mapping, trust-primitive reuse, and auth handling for github-api."
  validates [cap_forge_remote_ops]
  method runtime
  scenarios [github_api_provider_parity]
  proof_commands {
    command npm_test argv ["npm" "test"]
  }
  status active
}
