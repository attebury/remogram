verification verification_test_strategy_followup {
  name "Test strategy follow-up suite"
  description "Default provider wiring test, fetchTextCapped sanitize, coverage scope, and docs from PR #8 review lows."
  validates [cap_forge_remote_ops cap_validate_workspace]
  method runtime
  scenarios [test_strategy_followup_regression]
  proof_commands {
    command npm_test argv ["npm" "test"]
    command npm_test_coverage argv ["npm" "run" "test:coverage"]
  }
  status active
}
