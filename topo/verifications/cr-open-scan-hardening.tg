verification verification_cr_open_scan_hardening {
  name "CR open scan hardening proof"
  description "npm test proof for idempotency scan backoff, error fields allowlist, capabilities facts, and default-cap scan tests."
  validates [cap_forge_remote_ops]
  method runtime
  scenarios [cr_open_scan_hardening]
  proof_commands {
    command npm_test argv ["npm" "test"]
  }
  status draft
}
