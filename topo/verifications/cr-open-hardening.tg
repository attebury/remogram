verification verification_cr_open_hardening {
  name "CR open hardening proof"
  description "npm test proof for cr open config gate, idempotency, docs-adjacent contracts, and expanded provider CLI MCP tests."
  validates [cap_forge_remote_ops]
  method runtime
  scenarios [cr_open_hardening]
  proof_commands {
    command npm_test argv ["npm" "test"]
  }
  status draft
}
