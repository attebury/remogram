verification verification_cr_inventory_default_bounded {
  name "CR inventory default bounded proof"
  description "Core and CLI regression tests for default cr inventory path and limit>=4 bounded behavior."
  validates [cap_forge_remote_ops]
  method runtime
  scenarios [cr_inventory_default_bounded]
  proof_commands {
    command npm_test argv ["npm" "test"]
  }
  fixes_bugs [bug_cr_inventory_default_oversized_raw_output]
  status draft
}
