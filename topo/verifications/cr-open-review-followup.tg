verification verification_cr_open_review_followup {
  name "CR open review follow-up proof"
  description "npm test proof for paginated idempotency, packet fidelity, write enum, and negative MCP/doctor paths."
  validates [cap_forge_remote_ops]
  method runtime
  scenarios [cr_open_review_followup]
  proof_commands {
    command npm_test argv ["npm" "test"]
  }
  status draft
}
