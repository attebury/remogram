verification verification_cr_open_polish {
  name "CR open polish proof"
  description "npm test proof for pagination caps, idempotency_scan metadata, contract registry, and CLI/MCP truncated-scan paths."
  validates [cap_forge_remote_ops]
  method runtime
  scenarios [cr_open_polish]
  proof_commands {
    command npm_test argv ["npm" "test"]
  }
  status draft
}
