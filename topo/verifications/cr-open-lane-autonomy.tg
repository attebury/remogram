verification verification_cr_open_lane_autonomy {
  name "CR open lane autonomy proof"
  description "CLI, provider, and MCP tests for remogram cr open on Gitea."
  validates [cap_forge_remote_ops]
  method runtime
  scenarios [cr_open_lane_autonomy]
  proof_commands {
    command npm_test argv ["npm" "test"]
  }
  status draft
}
