verification verification_merge_plan_path_allowlist {
  name "Merge plan path allowlist proof"
  description "Unit tests for merge plan path scope blockers and git diff name-only helper."
  validates [cap_forge_remote_ops]
  method runtime
  scenarios [merge_plan_path_allowlist]
  proof_commands {
    command npm_test argv ["npm" "test" "tests/core/merge-blockers.test.mjs" "tests/core/merge-plan-path-scope.test.mjs"]
  }
  status draft
}
