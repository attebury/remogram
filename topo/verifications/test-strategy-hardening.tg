verification verification_test_strategy_hardening {
  name "Test strategy hardening suite"
  description "CI gate, expanded unit/integration tests, packet contracts, core coverage, and fixture hygiene from code review recommendations."
  validates [cap_forge_remote_ops cap_validate_workspace]
  method runtime
  scenarios [test_strategy_hardening_regression]
  proof_commands {
    command npm_test argv ["npm" "test"]
    command npm_test_coverage argv ["npm" "run" "test:coverage"]
  }
  status active
}
