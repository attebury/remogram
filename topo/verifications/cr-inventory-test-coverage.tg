verification verification_cr_inventory_test_coverage_wave4 {
  name "CR inventory test coverage wave 4"
  description "Provider matrix and pagination tests."
  validates [cap_forge_remote_ops]
  method runtime
  scenarios [cr_inventory_test_coverage_wave4]
  proof_commands {
    command npm_test argv ["npm" "test"]
    command topogram_check argv ["topogram" "check" "." "--json"]
  }
  status active
}
