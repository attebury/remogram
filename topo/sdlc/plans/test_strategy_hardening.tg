plan plan_test_strategy_hardening {
  name "Test Strategy Hardening Implementation Plan"
  description "Nine-step plan from maintainer code review; implement on goal/test-strategy-hardening targeting dev/scaffold."
  task task_test_strategy_hardening
  architecture_patterns [contract_boundary, command_owned_mutation]
  priority high
  steps {
    step add_ci_npm_test status done description "R1: GitHub Actions (or equivalent) workflow runs npm test on Node 20+ for push/PR."
    step test_assert_forge_ready status done description "R2: Table tests for assertForgeReady with temp config and mocked gitRemoteUrl/parseRemoteUrl paths."
    step test_cli_integration status done description "R3: Temp-dir CLI tests for all six commands using stub provider or provider injection."
    step test_packet_contracts status done description "R4: Golden/snapshot fixtures per PACKET_TYPES validating envelope and body shape."
    step test_http_expansion status done description "R5: Tests for oversized body, invalid JSON, sanitized API errors, redirect in fetchJson/fetchTextCapped."
    step test_coverage_core status done description "R6: Vitest coverage scoped to packages/remogram-core with npm script; optional threshold."
    step test_mcp_package_exports status done description "R7: Export MCP adapter helpers from package; update tests to import via @remogram/mcp."
    step doc_testing_readme status done description "R8: README Testing section — pyramid, mocks, git requirements, commands; dx/ excluded from test and coverage scope."
    step test_fixture_hygiene status done description "R9: Wire statuses-success.json into prChecks success test or delete orphaned fixture."
    step verify status done description "npm test, coverage run, topogram check green; all nine ACs satisfied."
  }
  status draft
}
