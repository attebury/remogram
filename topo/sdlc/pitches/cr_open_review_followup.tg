  solution_sketch "Single wave: paginated early-exit scan with idempotency_scan_incomplete fail-closed; reused_existing plus forge title on reuse; shared WRITE_COMMAND_IDS enum; consumer write boundary docs; regression tests for page-2 match, truncated scan, MCP write_not_configured, doctor write_config warn."
  rabbit_holes "Distributed locking; provider-level write gate refactor; merge execute; new write commands beyond cr_open."
  no_go_areas "Hand-editing lifecycle status; implementation in draft planning PR."
  affects [cap_forge_remote_ops]
  priority high
  status covered
}
