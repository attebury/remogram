pitch pitch_cr_open_review_followup {
  name "CR open review follow-up"
  description "Close code-review findings from cr-open-hardening (#285): paginated fail-closed idempotency, honest idempotent packets, write-command enum DRY, consumer boundary docs, negative MCP/doctor tests."
