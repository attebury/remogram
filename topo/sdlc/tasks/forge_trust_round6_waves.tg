task task_forge_trust_round6_wave1 {
  name "Wave 1 — Trust doctrine and doctor honesty"
  description "Implement packet trust split per decision_packet_trust_doctrine. Fix doctor exit code and ok flag. Fix sanitizeUrl credential leak. Scrub origin/remo from public-bound scripts."
