  phase implementation
  scope current_feature
  non_goals ["STALE_HEAD implementation" "Semantic packet schema redesign" "npm publish"]
  entrypoints ["AGENTS.md" "README.md" "tools/remogram-agent-support/skills/**" "packages/remogram-core/caps.js" "packages/remogram-cli/index.js" "scripts/run-secret-scan.mjs" "scripts/install-pre-push-hook.sh" "CHANGELOG.md"]
  satisfies [req_forge_trust_round6]
  acceptance_refs [ac_packet_trust_doctrine_round6, ac_doctor_fail_closed_round6, ac_sanitize_url_no_credentials_round6, ac_public_scripts_no_remo_default_round6]
  verification_refs [verification_forge_trust_round6_wave1]
  affects [cap_forge_remote_ops]
  blocked_by []
  architecture_patterns [contract_boundary, fail_closed_gate]
  disposition active
  priority critical
  work_type bugfix
  claimed_by [actor_coding_agent]
  bug_discovery bug_linked
  linked_bugs [bug_packet_trust_contradiction bug_doctor_exit_zero bug_doctor_ok_on_fail bug_sanitize_url_credentials bug_public_origin_remo_leak]
  status done
}

