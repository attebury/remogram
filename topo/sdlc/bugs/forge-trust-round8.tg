bug bug_github_link_next_unvalidated {
  name "GitHub Link rel=next URL not same-origin validated"
  description "githubFetchPaginated follows Link header next URLs with forge token without verifying origin matches configured API base; adversarial forge could exfiltrate token."
  fixed_in [task_forge_trust_round8_wave4]
  fixed_in_verification [verification_forge_trust_round8_wave4]
  status fixed
  severity high
  priority medium
  affects [cap_forge_remote_ops]
  failure_mode "Compromised self-hosted forge points next to off-host URL; Remogram fetches with Bearer token."
  linked_task task_forge_trust_round8_wave4
  reproduction "Inspect githubFetchPaginated; parseLinkHeader next URL fetched without host check."
  boundary_test_added true
}
