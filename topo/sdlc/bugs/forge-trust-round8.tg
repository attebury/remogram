bug bug_checks_truncation_silent {
  name "Check list truncation is silent at max_pages"
  description "paginateCheckStatusPages and githubFetchPaginated stop at MAX_CHECK_STATUS_PAGES without checks_truncated on pr_checks or checks_incomplete merge blocker; merge_plan may report success on partial enumeration."
  fixed_in [task_forge_trust_round8_wave2]
  fixed_in_verification [verification_forge_trust_round8_wave2]
  status fixed
  severity high
  priority high
  affects [cap_forge_remote_ops]
  failure_mode "Agents treat check_conclusion success as complete when checks on later pages were never fetched."
  linked_task task_forge_trust_round8_wave2
  reproduction "Mock forge returning full pages through page 50 with failure on page 51; pr_checks returns success without truncation signal."
  boundary_test_added true
}

bug bug_check_pagination_under_reports_bounds {
  name "check_pagination omits backoff and truncation semantics"
  description "Provider capabilities report static page_size and max_pages but not ingest_backoff halve_until_fit or on_page_cap set_checks_truncated behavior per decision_forge_ingest_cap_policy honest description requirement."
  fixed_in [task_forge_trust_round8_wave1]
  fixed_in_verification [verification_forge_trust_round8_wave1]
  status fixed
  severity medium
  priority high
  affects [cap_forge_remote_ops]
  failure_mode "Agents cannot discover adaptive page halving or truncation field from capabilities packet alone."
  linked_task task_forge_trust_round8_wave1
  reproduction "remogram provider capabilities --json; check_pagination lacks ingest_backoff and truncation_packet_field."
  boundary_test_added true
}

