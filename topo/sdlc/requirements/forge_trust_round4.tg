requirement req_forge_trust_round4 {
  name "Remogram beta hardening — trust doctrine, merge integrity, forge ingest"
  description "Remogram must distinguish trusted envelope metadata from untrusted forge-sourced strings in docs and agent guidance; emit honest doctor exit codes and ok flags; paginate or otherwise completely normalize check sources for merge_plan; keep default forge HTTP ingest at 8192 bytes without a .remogram.json cap knob; report ingest and pagination limits in provider capabilities; fix Gitea check/PR state normalization parity; remove spurious auth requirements from git-only commands; harden MCP schemas and export pipeline."
  affects [cap_forge_remote_ops]
  introduces_rules []
  respects_rules [rule_maintainable_security_focused_code, rule_tests_prove_consumer_value]
  priority critical
  status submitted
}
