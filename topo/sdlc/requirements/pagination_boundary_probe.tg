requirement req_pagination_boundary_probe {
  name "Pagination boundary probe at maxPages"
  description "paginateOffsetListPages must probe page+1 before setting list_truncated true when a full page lands on maxPages, for both bounded and unbounded list paths."
  affects [cap_forge_remote_ops]
  pitch pitch_inventory_post_review_hardening
  priority high
  status approved
}
