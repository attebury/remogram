requirement req_forge_trust_round6 {
  name "Remogram forge trust round 6 — close residual open bugs"
  description "Remogram must close all twelve open forge-trust-round4 bug records: distinguish trusted envelope from untrusted forge strings in agent docs; doctor fails closed on shell exit and packet ok; sanitizeUrl strips credentials; public export scripts default away from origin/remo; check listing paginates completely for merge_plan; Gitea check states normalize to shared enums; non-list forge ingest paths stay bounded under default 8192 via pagination not cap increase; MCP pr_checks rejects empty args; export denylist has regression test; core sanitizeField redacts secrets consistently with MCP; gitAheadBehind validates refs before compare."
  affects [cap_forge_remote_ops]
  introduces_rules []
  respects_rules [rule_maintainable_security_focused_code, rule_tests_prove_consumer_value]
  priority critical
  status satisfied
}
