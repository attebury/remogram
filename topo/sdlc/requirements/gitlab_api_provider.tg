requirement req_gitlab_api_provider {
  name "GitLab api provider parity with shared envelope"
  description "Remogram must support provider gitlab-api for all six read/plan commands against GitLab REST v4, emitting schema_version 1 packets compatible with existing shared shapes. GitLab merge requests must map to PR packet vocabulary, pipelines/statuses must normalize into the existing check_conclusion vocabulary, merge status must normalize into clean/conflicted/unknown, and API host selection must fail closed for gitlab.com and self-managed GitLab before sending tokens."
  affects [cap_forge_remote_ops]
  introduces_rules []
  respects_rules [rule_maintainable_security_focused_code, rule_tests_prove_consumer_value]
  priority high
  status draft
}
