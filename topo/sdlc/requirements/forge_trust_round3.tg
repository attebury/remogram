requirement req_forge_trust_round3 {
  name "Remogram forge trust fail-closed round 3"
  description "Remogram must bind gitea-api API traffic host to verified git remote host inside the provider, remove unused trustedHosts from config, and sanitize or cap MCP error text so stderr cannot leak token material to agents."
  affects [cap_forge_remote_ops]
  introduces_rules []
  respects_rules [rule_maintainable_security_focused_code, rule_tests_prove_consumer_value]
  priority high
  status satisfied
}
