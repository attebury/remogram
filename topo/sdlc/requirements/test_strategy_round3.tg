requirement req_test_strategy_round3 {
  name "Test strategy code review round 3"
  description "Remogram must test MCP ref injection and pr_checks paths, MCP stdout truncation, fetchJson redirect rejection, default PROVIDERS env isolation, document core-only coverage as intentional, and optionally exercise one real-provider CLI command per family with temp forge and mocked fetch."
  affects [cap_forge_remote_ops cap_validate_workspace]
  introduces_rules []
  respects_rules [rule_maintainable_security_focused_code, rule_tests_prove_consumer_value]
  priority medium
  status approved
}
