requirement req_open_pull_total_count_header {
  name "Trusted open-PR total count"
  description "When forge exposes a trusted total-count header or search total_count, cr inventory must set entry_count without full pagination and fail closed when total exceeds compliant_max_items."
  affects [cap_forge_remote_ops]
  pitch pitch_cr_inventory_list_v2
  priority high
  status satisfied
}
