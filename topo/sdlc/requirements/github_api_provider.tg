requirement req_github_api_provider {
  name "GitHub api provider parity with shared envelope"
  description "Remogram must support provider github-api for all six read/plan commands, emitting packets that conform to the existing shared shapes (schema_version 1) with only provider_id and provider-attributed values differing from gitea-api. GitHub check-runs and commit statuses must normalize into the existing check_conclusion vocabulary; mergeable_state must normalize into the existing mergeability vocabulary. The provider must reuse remogram-core trust primitives (manual redirect rejection, git argv allowlists, output caps and sanitization) and must remain fail-closed on API host selection: public github.com remotes may use only the fixed GitHub API origin https://api.github.com, while GitHub Enterprise remotes must derive the API base from the verified remote host using /api/v3 (or reject config that would send tokens to a different host). Any GitHub primitive that cannot map cleanly must be reported via capabilities and documented, not accommodated by changing the shared envelope or shapes."
  affects [cap_forge_remote_ops]
  introduces_rules []
  respects_rules [rule_maintainable_security_focused_code, rule_tests_prove_consumer_value]
  priority high
  status approved
}
