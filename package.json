{
  "name": "remogram",
  "version": "0.1.0-beta.3",
  "private": true,
  "description": "Generic SCM/forge boundary CLI and MCP — provider-attributed forge facts only",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/attebury/remogram.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke:compare-pr-view": "node ./scripts/remogram-smoke-compare.mjs",
    "smoke:compare-pr-checks": "node ./scripts/remogram-smoke-compare-pr-checks.mjs",
    "smoke:compare-ref-compare": "node ./scripts/remogram-smoke-compare-ref-compare.mjs",
    "security:secrets": "node ./scripts/run-secret-scan.mjs"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
